      "id": "lookup-cliques",
      "name": "Lookup Cliques",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [680, 300]
    },
    {
      "parameters": {
        "jsCode": "const crypto = require('crypto');\n\nconst lead = $('Filtro Status').first().json;\nconst click = $input.first().json;\n\n// Limpar telefone\nlet phone = (lead.telefone || lead.phone || '').replace(/\\D/g, '');\nif (phone.length === 11) phone = '55' + phone;\nelse if (phone.length === 10) phone = '55' + phone;\n\n// SHA256 hash para Meta CAPI\nconst phoneHash = crypto.createHash('sha256').update(phone).digest('hex');\n\n// Evento baseado no status\nconst status = (lead.status || '').toLowerCase();\nconst eventName = status === 'vendido' ? 'Purchase' : 'Lead';\nconst value = parseFloat(lead.valor) || 0;\n\nreturn {\n  json: {\n    event_name: eventName,\n    event_time: Math.floor(Date.now() / 1000),\n    phone_raw: phone,\n    phone_hash: phoneHash,\n    name: lead.nome || lead.name || '',\n    status: lead.status,\n    value: value,\n    segment: lead.segmento || lead.segment || '',\n    ref: lead.ref || '',\n    fbc: click.fbc || '',\n    fbp: click.fbp || '',\n    gclid: click.gclid || '',\n    utm_source: click.utm_source || '',\n    utm_campaign: click.utm_campaign || '',\n    utm_content: click.utm_content || '',\n    lp: click.lp || '',\n    has_meta: !!(click.fbc || click.fbp || phone),\n    has_google: !!click.gclid\n  }\n};"
      },
      "id": "merge-hash",
      "name": "Merge e Hash",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://graph.facebook.com/v23.0/1667309107949808/events",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"data\": [{\n    \"event_name\": \"{{ $json.event_name }}\",\n    \"event_time\": {{ $json.event_time }},\n    \"action_source\": \"website\",\n    \"event_source_url\": \"https://www.titaniumconsultorias.com.br/{{ $json.lp }}\",\n    \"user_data\": {\n      {{ $json.fbc ? '\"fbc\": \"' + $json.fbc + '\",' : '' }}\n      {{ $json.fbp ? '\"fbp\": \"' + $json.fbp + '\",' : '' }}\n      \"ph\": [\"{{ $json.phone_hash }}\"],\n      \"country\": [\"br\"]\n    },\n    \"custom_data\": {\n      \"currency\": \"BRL\",\n      \"value\": {{ $json.value || 0 }},\n      \"content_name\": \"{{ $json.segment }}\"\n    }\n  }],\n  \"access_token\": \"EAANm3XxZAvvUBRjHxpcpIZBWrNCbEnzHzHA5p9OE4WZAIlJT6GfNZAf30ops3CS5ZB90tHay9BBjQFq6pj73MmJN2fhQELTZCnDtw40RYAtKYXiJ9EaIzMYE7jbdzujxo6s7LZBYZAKNxFoQfjFGHIYwMpEZA3Ogt2lBP2LaAwLdUqzabFTWmed9qNcW3sgzR8AZDZD\"\n}",
        "options": {}
      },
      "id": "meta-capi",
      "name": "Meta CAPI",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1140, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://googleads.googleapis.com/v17/customers/8875758127:uploadClickConversions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleAdsOAuth2Api",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"conversions\": [{\n    \"gclid\": \"{{ $json.gclid }}\",\n    \"conversion_action\": \"customers/8875758127/conversionActions/kTjGCO35_r0cELK2ivND\",\n    \"conversion_date_time\": \"{{ new Date().toISOString().replace('T', ' ').substring(0, 19) }}+00:00\",\n    \"conversion_value\": {{ $json.value || 0 }},\n    \"currency_code\": \"BRL\"\n  }],\n  \"partialFailure\": true\n}",
        "options": {}
      },
      "id": "google-oc",
