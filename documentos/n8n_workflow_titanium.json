      "id": "filter-status",
      "name": "Filtro Status",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "documentId": {
          "value": "1meDMu6aVxC6o08eBYu1vu0kLO7Es1BzOzHTbuzdkqkQ",
          "__rl": true,
          "mode": "id"
        },
        "sheetName": {
          "value": "Cliques",
          "__rl": true,
          "mode": "name"
        },
        "filtersUI": {
