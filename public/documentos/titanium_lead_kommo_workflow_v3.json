      "id": "node-http-001",
      "name": "Cria Lead no Kommo",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [720, 300]
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst leadId = response?._embedded?.leads?.[0]?.id;\n\nif (!leadId) {\n  throw new Error('Lead ID nao encontrado: ' + JSON.stringify(response));\n}\n\nconst nota = $('Formata Payload Kommo').first().json.nota;\nconst ref = $('Formata Payload Kommo').first().json.ref;\n\nconst notePayload = JSON.stringify([\n  {\n    entity_id: leadId,\n    note_type: 'common',\n    params: { text: nota }\n  }\n]);\n\nreturn [{ json: { leadId, notePayload, ref } }];"
      },
