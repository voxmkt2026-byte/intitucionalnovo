      "id": "node-webhook-001",
      "name": "Webhook Recebe Lead",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "titanium-lead-create"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\nconst rawPhone = (body.phone || '').replace(/\\D/g, '');\nconst phone = rawPhone.startsWith('55') ? '+' + rawPhone : '+55' + rawPhone;\n\nconst creditRaw = String(body.credit || '0').replace(/\\D/g, '');\nconst creditValue = parseInt(creditRaw) || 0;\n\nconst leadName = 'Lead - ' + (body.segment || 'Geral') + ' | ' + (body.lp || body.utm_source || 'site');\n\nconst tags = [];\nif (body.lp) tags.push({ name: body.lp });\nif (body.utm_source) tags.push({ name: body.utm_source });\nif (body.utm_campaign) tags.push({ name: body.utm_campaign });\n\nconst nota = [\n  '📋 Lead do formulário',\n  'Nome: ' + (body.name || '-'),\n  'Email: ' + (body.email || '-'),\n  'Telefone: ' + phone,\n  'Segmento: ' + (body.segment || '-'),\n  'Crédito: R$ ' + creditValue.toLocaleString('pt-BR'),\n  'Prazo: ' + (body.months || '-') + ' meses',\n  'Plano: ' + (body.plan || '-'),\n  'LP: ' + (body.lp || '-'),\n  'UTM Source: ' + (body.utm_source || '-'),\n  'UTM Campaign: ' + (body.utm_campaign || '-'),\n  'Ref: ' + (body.ref || '-'),\n  'Data: ' + new Date().toLocaleString('pt-BR')\n].join('\\n');\n\n// Payload Kommo como string JSON pronta para envio\nconst kommoPayload = JSON.stringify([\n  {\n    name: leadName,\n    price: creditValue,\n    pipeline_id: 13995439,\n    _embedded: {\n      contacts: [\n        {\n          name: body.name || 'Lead sem nome',\n          custom_fields_values: [\n            { field_code: 'PHONE', values: [{ value: phone, enum_code: 'WORK' }] },\n            { field_code: 'EMAIL', values: [{ value: body.email || '', enum_code: 'WORK' }] }\n          ]\n        }\n      ],\n      tags: tags\n    }\n  }\n]);\n\nreturn [{\n  json: {\n    leadName,\n    contactName: body.name || 'Lead sem nome',\n    phone,\n    email: body.email || '',\n    creditValue,\n    nota,\n    ref: body.ref || '',\n    kommoPayload\n  }\n}];"
      },
