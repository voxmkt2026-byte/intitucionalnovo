        "responseMode": "responseNode",
        "options": {}
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000001",
      "name": "Webhook Recebe Lead",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "titanium-lead-create"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\n// Formata telefone para padrao Kommo\nconst rawPhone = (body.phone || '').replace(/\\D/g, '');\nconst phone = rawPhone.startsWith('55') ? '+' + rawPhone : '+55' + rawPhone;\n\n// Valor do credito em centavos para o Kommo (usa campo price)\nconst creditRaw = String(body.credit || '0').replace(/\\D/g, '');\nconst creditValue = parseInt(creditRaw) || 0;\n\n// Nome do lead no Kommo\nconst leadName = `Lead - ${body.segment || 'Geral'} | ${body.lp || body.utm_source || 'site'}`;\n\n// Tags: LP + UTM source\nconst tags = [];\nif (body.lp) tags.push({ name: body.lp });\nif (body.utm_source) tags.push({ name: body.utm_source });\nif (body.utm_campaign) tags.push({ name: body.utm_campaign });\n\n// Nota com dados completos\nconst nota = [\n  `📋 Lead do formulario`,\n  `Segmento: ${body.segment || '-'}`,\n  `Credito: R$ ${creditValue.toLocaleString('pt-BR')}`,\n  `Prazo: ${body.months || '-'} meses`,\n  `LP: ${body.lp || '-'}`,\n  `UTM Source: ${body.utm_source || '-'}`,\n  `UTM Medium: ${body.utm_medium || '-'}`,\n  `UTM Campaign: ${body.utm_campaign || '-'}`,\n  `Ref: ${body.ref || '-'}`,\n  `Timestamp: ${body.timestamp || new Date().toISOString()}`\n].join('\\n');\n\nreturn [{\n  json: {\n    leadName,\n    contactName: body.name || 'Lead sem nome',\n    phone,\n    email: body.email || '',\n    creditValue,\n    tags,\n    nota,\n    segment: body.segment || '',\n    lp: body.lp || '',\n    ref: body.ref || ''\n  }\n}];"
      },
      "id": "a1b2c3d4-0002-0002-0002-000000000002",
      "name": "Formata Payload Kommo",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 300]
    },
